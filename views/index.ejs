<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini WhatsApp</title>
</head>
<body>
    <h3>All Chats!</h3>

    <% for(let chat of chats){ %>
    <div class="chat">
        <p>From : <%=chat.from%> </p>
        <div class="message">
            <p> <%=chat.message%> </p>
        </div>
        <p>Received By : <%=chat.to%> </p>
        <hr>
    </div>
    <% } %>

</body>
</html>
